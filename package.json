{
  "name": "vscode-spotlight-search",
  "displayName": "Spotlight Search",
  "description": "IntelliJ-style Find in Path dialog and results panel for VS Code",
  "version": "0.1.0",
  "publisher": "local",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "intellijSearch.open",
        "title": "Find in Path (IntelliJ Style)",
        "category": "Search"
      }
    ],
    "keybindings": [
      {
        "command": "intellijSearch.open",
        "key": "ctrl+shift+alt+f",
        "mac": "cmd+shift+alt+f",
        "when": "!terminalFocus"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "intellijSearchResults",
          "title": "Find in Path",
          "icon": "resources/search.svg"
        }
      ]
    },
    "views": {
      "intellijSearchResults": [
        {
          "type": "webview",
          "id": "intellijSearch.resultsView",
          "name": "Results"
        }
      ]
    },
    "configuration": {
      "title": "IntelliJ Search",
      "properties": {
        "intellijSearch.defaultContextLines": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 5,
          "description": "Number of context lines to show above and below each match"
        },
        "intellijSearch.maxResults": {
          "type": "number",
          "default": 5000,
          "description": "Maximum number of results to display"
        },
        "intellijSearch.batchSize": {
          "type": "number",
          "default": 20,
          "description": "Number of results to accumulate before flushing to the panel"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "pack-extension": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}
